# --- Chain (local forge-fhevm Anvil; run it with `anvil --block-time 1`) ---
RPC_URL=http://127.0.0.1:8545

# --- The single ERC-7984 token to index (written by demo/bootstrap.sh) ---
TOKEN_ADDRESS=0x484e39c4e89280a2bae7126ec14e39e3d8801ce2

# --- The indexer's decryption identity ---
# An EOA that wallet-partner holders delegate decryption rights to (Anvil account #3 by default).
INDEXER_PRIVATE_KEY=0x7c852118294e51e653712a81e05800f419141751be58f605c371e15141b007a6

# --- Indexing window + reconciler cadence ---
START_BLOCK=0
RECONCILE_BLOCK_INTERVAL=1   # run the decrypt/backfill reconciler every N blocks
RECONCILE_BATCH=25           # max undecrypted rows processed per reconcile tick
RECONCILE_MAX_ATTEMPTS=25    # stop retrying a row after this many failed decrypts (safety valve)

# --- /v1/health turns 503 when (chain head - lastIndexedBlock) exceeds this ---
HEALTH_LAG_THRESHOLD=25
